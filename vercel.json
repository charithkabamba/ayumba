{
    "version": 2,
    "builds": [
        {
            "src": "ar/wsgi.py",
            "use": "@vercel/python",
            "config": {
                "maxLambdaSize": "50mb"
            }
        }
    ],
    "routes": [
        {
            "src": "/(.*)",
            "dest": "ar/wsgi.py"
        }
    ],
    "env": {
        "DJANGO_SETTINGS_MODULE": "ar.settings",
        "PYTHONPATH": "."
    }
}